<style>
  .search-btn{
    background-color: #fe424d;
    color: #fff;
    border-radius: 20px;
  padding: 0.5rem 1rem 0.5rem 1rem;
  }
  .search-btn:hover{
    background-color: #fe424d;
    color: #fff;
  }
.search-btn i{
  display: inline;
  margin-right: 0.5rem;
}
.search-inp{
  border-radius: 20px;
  padding: 0.5rem 3rem 0.5rem 3rem;
  font-size: 0.9rem;
}


</style>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
    <div class="container-fluid">
      <a class="navbar-brand" href="/listings"><i class="fa-regular fa-compass"></i></a>
      <button class="navbar-toggler"
          type="button"
            data-bs-toggle="collapse" 
            data-bs-target="#navbarNavAltMarkup">

        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
        <div class="navbar-nav">
          <a class="nav-link mr-2" href="/listings"
            style="color: #333; font-weight: 500; padding: 8px 16px; text-decoration: none; border-radius: 6px; transition: background-color 0.3s ease;"
              onmouseover="this.style.backgroundColor='#f0f0f0'"
              onmouseout="this.style.backgroundColor='transparent'"
          >Explore</a>
        </div>
        <div class="navbar-nav ms-auto">
             <form class="d-flex" role="search"  action="/listings/search" method="GET">
        <input class="form-control me-2 search-inp" 
           type="search"
           name="q" 
            value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
             placeholder="Search Destination" 
             aria-label="Search"
             />
        <button class="btn search-btn" type="submit"><i class="fa-solid fa-magnifying-glass"></i>Search</button>
      </form>
        </div>

         <div class="navbar-nav  ms-auto"> 
           <a class="nav-link mr-2" href="/listings/new"
           style="background-color: #20c997; color: white; padding: 10px 18px; border-radius: 8px; font-weight: bold; text-decoration: none; display: inline-block; transition: all 0.3s ease;"
  onmouseover="this.style.backgroundColor='#20c997'; this.style.transform='scale(1.05)'"
  onmouseout="this.style.backgroundColor='#20c997'; this.style.transform='scale(1)'"

           ><i class="fas fa-home"></i> Airbnb your home</a>
          <% if(!currUser) { %>
          <a class="nav-link ms-2 mr-2"  title="Create your account by clicking on it"
            style="color: #333; font-weight: 500; padding: 8px 16px; text-decoration: none; border-radius: 6px; transition: background-color 0.3s ease;"
              onmouseover="this.style.backgroundColor='#f0f0f0'"
              onmouseout="this.style.backgroundColor='transparent'"
             href="/signup"><b>Sign up</b></a>
          <a class="nav-link btn btn-outline-primary  rounded-pill px-3 py-2 me-2 mr-2"  href="/login"><b>Log in</b></a>
          <% } %>
            <% if(currUser) { %>
          <a class="nav-link btn btn-outline-danger rounded-pill px-3 py-2 me-2 mr-2" href="/logout"><b>Log out</b></a>
          <% } %>
        </div>

      </div>
    </div>
  </nav>