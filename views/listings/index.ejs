<% layout('/layouts/boilerplate') -%>
<style>
  .container{
     display: flex;
      flex-wrap: wrap;
      align-items: center;
  }

    #filters {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
    }

    .filter {
      text-align: center;
      margin-right: 2rem;
      margin-top: 1.5rem;
      opacity: 0.7;
    }

    .filter:hover {
      opacity: 1;
      cursor: pointer;
    }

    .filter p {
      font-size: 0.8rem;
    }

    .tax-info {
      display: none;
    }

    .tax-toggle {
      border: 1px solid black;
      border-radius: 1rem;
      height: 3.2rem;
      padding: 1rem;
      margin-left: 2rem;
      display: flex;
      align-items: center;
      margin-top: 1.5rem;
      margin-bottom: 2rem;
    }

    /* Hide inline filters on small screens */
    @media (max-width: 768px) {
      #filters {
        display: none;
      }
    }

    .f-info{
        margin-left: 10rem;
    }
  </style>
<div class="container mt-3">

    <!-- Toggle Button for Offcanvas (Mobile only) -->
    <button class="btn  btn-outline-info d-md-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#filterSidebar" aria-controls="filterSidebar">
      category
    </button>

    <!-- Offcanvas Sidebar -->
    <div class="offcanvas offcanvas-start" tabindex="-1" id="filterSidebar" aria-labelledby="filterSidebarLabel">
      <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="filterSidebarLabel">Filters</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
      </div>
      <div class="offcanvas-body">
        <div class="d-flex flex-wrap" id="offcanvas-filters">
          <!-- Copy your filters here -->
          <div class="filter"><i class="fa-solid fa-fire"></i><p>Trending</p></div>
          <div class="filter"><i class="fa-solid fa-bed"></i><p>Room</p></div>
          <div class="filter"><i class="fa-solid fa-mountain-city"></i><p>Iconic cities</p></div>
          <div class="filter"><i class="fa-solid fa-mountain"></i><p>Mountains</p></div>
          <div class="filter"><i class="fa-brands fa-fort-awesome"></i><p>Castles</p></div>
          <div class="filter"><i class="fa-solid fa-person-swimming"></i><p>Amazing pools</p></div>
          <div class="filter"><i class="fa-solid fa-campground"></i><p>Camping</p></div>
          <div class="filter"><i class="fa-solid fa-cow"></i><p>Farms</p></div>
          <div class="filter"><i class="fa-solid fa-snowflake"></i><p>Arctic</p></div>
          <div class="filter"><i class="fa-solid fa-igloo"></i><p>Domes</p></div>
          <div class="filter"><i class="fa-solid fa-sailboat"></i><p>House Boat</p></div>

          <!-- Tax Toggle in Offcanvas -->
          <div class="tax-toggle">
            <div class="form-check form-switch form-check-reverse">
              <input class="form-check-input" type="checkbox" id="switchCheckReverseSidebar">
              <label class="form-check-label" for="switchCheckReverseSidebar">Display total after taxes</label>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Inline Filters (visible on medium and large screens) -->
    <div id="filters">
      <div class="filter"><i class="fa-solid fa-fire"></i><p>Trending</p></div>
      <div class="filter"><i class="fa-solid fa-bed"></i><p>Room</p></div>
      <div class="filter"><i class="fa-solid fa-mountain-city"></i><p>Iconic cities</p></div>
      <div class="filter"><i class="fa-solid fa-mountain"></i><p>Mountains</p></div>
      <div class="filter"><i class="fa-brands fa-fort-awesome"></i><p>Castles</p></div>
      <div class="filter"><i class="fa-solid fa-person-swimming"></i><p>Amazing pools</p></div>
      <div class="filter"><i class="fa-solid fa-campground"></i><p>Camping</p></div>
      <div class="filter"><i class="fa-solid fa-cow"></i><p>Farms</p></div>
      <div class="filter"><i class="fa-solid fa-snowflake"></i><p>Arctic</p></div>
      <div class="filter"><i class="fa-solid fa-igloo"></i><p>Domes</p></div>
      <div class="filter"><i class="fa-solid fa-sailboat"></i><p>House Boat</p></div>

      <!-- Tax Toggle -->
      <div class="tax-toggle">
        <div class="form-check form-switch form-check-reverse">
          <input class="form-check-input" type="checkbox" id="switchCheckReverse">
          <label class="form-check-label" for="switchCheckReverse">Display total after taxes</label>
        </div>
      </div>
    </div>
  </div>

<!-- do here -->

<% if (typeof searchQuery !== 'undefined') { %>
  <h4 class="mb-4">Search results for: "<%= searchQuery %>"</h4>
<% } %>

<% if (allListings.length === 0) { %>
  <p class="text-muted">No listings found.</p>
<% } %>

    <div class="row row-cols-lg-3 row-cols-md-3 row-cols-sm-1">
        <% for( listing of allListings) { %>
            <a href="/listings/<%= listing._id %>" class="listing-link">
            <div class="card listing-card">
                <img src="<%=listing.image.url%>" class="card-img-top" alt="..." style="height: 20rem;">
                <div class="card-img-overlay">Please  click</div>
                <div class="card-body">
                  <p class="card-text"><b><%= listing.title %></b><br>
                   &#8377; <%= listing.price.toLocaleString("en-IN")%> / night 
                  <i class="tax-info">&nbsp;&nbsp+ 18% GST</i>

                  </p> 
                   
                  <!-- <a href="#" class="btn btn-primary">Go somewhere</a> -->
                </div>
              </div>
            </a>
              <% } %>
    </div>
  
    <script>
      let taxSwitch = document.getElementById("switchCheckReverse");
      
      taxSwitch.addEventListener("click",()=>{
      let taxInfo = document.getElementsByClassName("tax-info");
      for(info of taxInfo){
        if(info.style.display != "inline"){
          info.style.display = "inline";
        }else{
          info.style.display = "none";
        }
      }
      });
    </script>

